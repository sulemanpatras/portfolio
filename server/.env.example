# Copy this file to .env and fill in real values. Never commit .env itself.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-address@gmail.com
SMTP_PASS=your-16-char-app-password

# Address that receives messages submitted through the portfolio contact form
CONTACT_TO=your-address@gmail.com

# Comma separated list of origins allowed to call this API
CORS_ORIGIN=https://sulemanpatras.github.io/portfolio/

PORT=4000
